# ══════════════════════════════════════════════════════════════════════
# AI Auditor — Environment Variables Reference
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ══════════════════════════════════════════════════════════════════════

# ── Core Django ────────────────────────────────────────────────────────


# ── Neon PostgreSQL (existing — unchanged) ─────────────────────────────


# ── LLM & Transcription (existing — unchanged) ────────────────────────
OPENROUTER_API_KEY=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
DEEPGRAM_API_KEY=249d5ee9ff7479b473f5281c41e45f24c8bebbec

# ── Milestone 3: LLM Provider Abstraction ─────────────────────────────
# Options: openrouter | openai | groq | together
ACTIVE_LLM_PROVIDER=openrouter
OPENAI_API_KEY=sk-...       # optional: if using OpenAI directly
GROQ_API_KEY=gsk_...        # optional: Groq fallback
TOGETHER_API_KEY=...        # optional: Together.AI fallback
MAX_TOKENS_PER_AUDIT=1500

# ── Milestone 3: Milvus Vector Database ───────────────────────────────
# Dev/Demo  (Milvus Lite, embedded, no server):
MILVUS_URI=./milvus_local.db
# Production (Milvus Standalone in Docker):
# MILVUS_URI=grpc://milvus:19530
MILVUS_TOKEN=                 # leave empty for local; set for Zilliz Cloud

# ── Milestone 3: Real-time (Django Channels) ──────────────────────────
# Dev: uses InMemoryChannelLayer (no Redis needed)
# Production: set REDIS_URL to enable Redis-backed channels
REDIS_URL=redis://localhost:6379

# ── Milestone 4: Alert Dispatch ───────────────────────────────────────
ALERT_WEBHOOK_URL=            # POST target for compliance alerts (optional)
# SMTP for email alerts (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your-app-password
